          "urlTemplate": "https://{your-domain}/api/{user-collection}/refresh-token"
        },
        {
          "@type": "Action",
          "name": "Get Current User",
          "httpMethod": "GET",
          "urlTemplate": "https://{your-domain}/api/{user-collection}/me"
        },
        {
