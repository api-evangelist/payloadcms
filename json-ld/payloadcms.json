      "https://www.linkedin.com/company/payload-cms"
    ]
  },
  "hasPart": [
    {
      "@type": "WebAPI",
      "@id": "https://payloadcms.com/docs/rest-api/overview",
      "name": "Payload CMS REST API",
      "description": "Auto-generated RESTful API for managing collections, globals, media uploads, users, and preferences. Mounted at /api/{collection-slug} with full CRUD operations plus authentication endpoints.",
      "documentation": "https://payloadcms.com/docs/rest-api/overview",
      "endpointUrl": "https://{your-domain}/api",
      "potentialAction": [
        {
          "@type": "SearchAction",
          "name": "Find Documents",
          "httpMethod": "GET",
          "urlTemplate": "https://{your-domain}/api/{collection-slug}"
        },
        {
          "@type": "FindAction",
          "name": "Find Document By ID",
          "httpMethod": "GET",
          "urlTemplate": "https://{your-domain}/api/{collection-slug}/{id}"
        },
        {
          "@type": "CreateAction",
          "name": "Create Document",
          "httpMethod": "POST",
          "urlTemplate": "https://{your-domain}/api/{collection-slug}"
        },
        {
          "@type": "UpdateAction",
          "name": "Update Document By ID",
          "httpMethod": "PATCH",
          "urlTemplate": "https://{your-domain}/api/{collection-slug}/{id}"
        },
        {
          "@type": "DeleteAction",
          "name": "Delete Document By ID",
          "httpMethod": "DELETE",
          "urlTemplate": "https://{your-domain}/api/{collection-slug}/{id}"
        },
        {
          "@type": "SearchAction",
