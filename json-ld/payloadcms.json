          "name": "Verify User",
          "httpMethod": "POST",
          "urlTemplate": "https://{your-domain}/api/{user-collection}/verify/{token}"
        },
        {
          "@type": "Action",
          "name": "Unlock User",
          "httpMethod": "POST",
          "urlTemplate": "https://{your-domain}/api/{user-collection}/unlock"
        },
        {
          "@type": "FindAction",
          "name": "Get Global",
          "httpMethod": "GET",
          "urlTemplate": "https://{your-domain}/api/globals/{global-slug}"
        },
        {
          "@type": "UpdateAction",
          "name": "Update Global",
          "httpMethod": "POST",
          "urlTemplate": "https://{your-domain}/api/globals/{global-slug}"
        },
        {
          "@type": "FindAction",
          "name": "Get Preference",
          "httpMethod": "GET",
          "urlTemplate": "https://{your-domain}/api/payload-preferences/{key}"
        },
        {
          "@type": "CreateAction",
          "name": "Create Preference",
          "httpMethod": "POST",
          "urlTemplate": "https://{your-domain}/api/payload-preferences/{key}"
        },
        {
          "@type": "DeleteAction",
          "name": "Delete Preference",
          "httpMethod": "DELETE",
          "urlTemplate": "https://{your-domain}/api/payload-preferences/{key}"
        }
      ]
    },
    {
      "@type": "WebAPI",
      "@id": "https://payloadcms.com/docs/graphql/overview",
      "name": "Payload CMS GraphQL API",
      "description": "Fully featured GraphQL API exposed at /api/graphql with auto-generated types for all collections and globals. Includes a GraphQL Playground at /api/graphql-playground and supports complexity limiting.",
      "documentation": "https://payloadcms.com/docs/graphql/overview",
      "endpointUrl": "https://{your-domain}/api/graphql"
    },
    {
      "@type": "SoftwareLibrary",
      "@id": "https://payloadcms.com/docs/local-api/overview",
      "name": "Payload CMS Local API",
      "description": "Server-side Node.js API for direct database interaction without HTTP overhead. Supports all collection and global operations including authentication, ideal for React Server Components.",
      "documentation": "https://payloadcms.com/docs/local-api/overview"
    }
